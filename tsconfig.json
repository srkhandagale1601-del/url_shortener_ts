{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "sourceMap": true,

    "types": ["node"],

    "esModuleInterop": true,

    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },

  "include": ["src"]
}